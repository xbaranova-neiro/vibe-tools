# OpenAI — обязательно для «Создать с нуля»
OPENAI_API_KEY=sk-...

OPENAI_MODEL=gpt-4.1-mini
OPENAI_CREATE_MODEL=gpt-4.1-mini

# Если api.openai.com недоступен с сервера — URL прокси (опционально)
# OPENAI_BASE_URL=https://your-proxy.example/v1

# Таймаут запроса к OpenAI, мс (на Timeweb можно 90000)
# OPENAI_TIMEOUT_MS=90000

# Публичный URL сайта (без / в конце) — после деплоя на Timeweb
NEXT_PUBLIC_APP_URL=https://ваш-домен.timeweb.cloud
APP_URL=https://ваш-домен.timeweb.cloud

# Ссылка на Timeweb с Vercel (опционально, для подсказки в UI)
# NEXT_PUBLIC_TIMEWEB_URL=https://ваш-домен.timeweb.cloud
