# OpenAI — обязательно для своих идей (шаблоны работают без API)
OPENAI_API_KEY=sk-...

# Модели (опционально)
OPENAI_MODEL=gpt-4.1-mini
OPENAI_CREATE_MODEL=gpt-4.1-mini

# Публичный URL сайта — для Timeweb/VPS (без слэша в конце)
# Пример: https://vibe-tools-xxxxx.timeweb.cloud
NEXT_PUBLIC_APP_URL=
APP_URL=

# Vercel Blob — только если остаётесь на Vercel (опционально)
# BLOB_READ_WRITE_TOKEN=

# Папка для сохранённых мини-приложений на диске (Timeweb/VPS)
# APP_DATA_DIR=/var/data/vibe-apps
